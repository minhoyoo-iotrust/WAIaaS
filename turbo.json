{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "@waiaas/skills#build": {
      "dependsOn": [],
      "outputs": ["dist/**", "skills/**"]
    },
    "@waiaas/openclaw-plugin#build": {
      "dependsOn": ["@waiaas/sdk#build"],
      "outputs": ["dist/**"]
    },
    "@waiaas/mcp#test:unit": {
      "dependsOn": [],
      "outputs": ["coverage/**"]
    },
    "@waiaas/mcp#build": {
      "dependsOn": [],
      "outputs": ["dist/**"]
    },
    "//#generate:api-types": {
      "dependsOn": ["@waiaas/core#build", "@waiaas/shared#build", "@waiaas/actions#build", "@waiaas/adapter-evm#build", "@waiaas/adapter-solana#build"],
      "outputs": ["packages/admin/src/api/types.generated.ts", "packages/admin/openapi.json"],
      "cache": false
    },
    "@waiaas/admin#build": {
      "dependsOn": ["@waiaas/shared#build", "//#generate:api-types"],
      "outputs": ["dist/**"]
    },
    "@waiaas/daemon#build": {
      "dependsOn": ["@waiaas/admin#build", "^build"],
      "outputs": ["dist/**", "public/**"]
    },
    "test": {
      "dependsOn": ["build"],
      "outputs": []
    },
    "test:unit": {
      "dependsOn": ["build"],
      "outputs": ["coverage/**"]
    },
    "test:integration": {
      "dependsOn": ["build"],
      "outputs": []
    },
    "test:security": {
      "dependsOn": ["build"],
      "outputs": []
    },
    "test:chain": {
      "dependsOn": ["build"],
      "outputs": []
    },
    "test:platform": {
      "dependsOn": ["build"],
      "outputs": []
    },
    "lint": {
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "clean": {
      "cache": false
    }
  }
}
