{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.minhoyoo-iotrust/waiaas",
  "title": "WAIaaS - Wallet-as-a-Service for AI Agents",
  "description": "Self-hosted wallet for AI agents. 60 tools: transfers, DeFi, NFTs, x402. EVM + Solana.",
  "version": "2.11.0",
  "websiteUrl": "https://github.com/minhoyoo-iotrust/WAIaaS",
  "repository": {
    "url": "https://github.com/minhoyoo-iotrust/WAIaaS",
    "source": "github",
    "id": "1149407153"
  },
  "packages": [
    {
      "registryType": "npm",
      "registryBaseUrl": "https://registry.npmjs.org",
      "identifier": "@waiaas/mcp",
      "version": "2.11.0",
      "transport": {
        "type": "stdio"
      },
      "runtimeHint": "npx",
      "environmentVariables": [
        {
          "name": "WAIAAS_BASE_URL",
          "description": "WAIaaS daemon API endpoint",
          "isRequired": false,
          "isSecret": false,
          "defaultValue": "http://127.0.0.1:3100"
        },
        {
          "name": "WAIAAS_SESSION_TOKEN",
          "description": "Session token for daemon authentication",
          "isRequired": false,
          "isSecret": true
        },
        {
          "name": "WAIAAS_WALLET_ID",
          "description": "Target wallet ID for single-wallet mode",
          "isRequired": false,
          "isSecret": false
        },
        {
          "name": "WAIAAS_DATA_DIR",
          "description": "Directory for session token storage",
          "isRequired": false,
          "isSecret": false
        }
      ]
    }
  ],
  "remotes": []
}
