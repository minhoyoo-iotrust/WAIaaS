<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Required for V8 JIT in the Node.js SEA daemon sidecar.
         Without allow-jit, pthread_jit_write_protect_np() traps with SIGTRAP
         during V8::Initialize() under Hardened Runtime (see issue 485). -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <!-- Conservative fallback for V8 code page allocation on older macOS. -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <!-- Required for dlopen of native addons (sodium-native, better-sqlite3, etc.)
         that are not signed by the same Team ID as the host binary. -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
</dict>
</plist>
