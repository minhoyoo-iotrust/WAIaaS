{
  "$schema": "https://raw.githubusercontent.com/nickel-org/nickel.rs/master/examples/example_assets/schema.json",
  "productName": "WAIaaS Desktop",
  "version": "2.13.0-rc.2",
  "identifier": "dev.waiaas.desktop",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "WAIaaS Desktop",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "url": "splash.html"
      }
    ],
    "security": {
      "csp": "default-src 'self' http://127.0.0.1:* http://localhost:*; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; connect-src 'self' http://127.0.0.1:* http://localhost:* wss://relay.walletconnect.com https://rpc.walletconnect.com https://pulse.walletconnect.org; img-src 'self' data: https:; font-src 'self'; frame-src https://secure.walletconnect.com"
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ],
    "externalBin": [
      "binaries/waiaas-daemon"
    ],
    "createUpdaterArtifacts": "v1Compatible",
    "macOS": {
      "minimumSystemVersion": "10.15",
      "signingIdentity": null,
      "providerShortName": null
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/minhoyoo-iotrust/WAIaaS/releases/latest/download/latest.json"
      ],
      "pubkey": "PLACEHOLDER_REPLACE_WITH_REAL_KEY"
    }
  }
}
